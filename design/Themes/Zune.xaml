<!--
  Zune.xaml — Zune HD design language for WinUI 3 / Windows App SDK

  USAGE
  =====
  1. Save this file as /Themes/Zune.xaml in your WinUI 3 project.
  2. In App.xaml, merge it into the application resources AND force dark theme:

         <Application
             x:Class="YourApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             RequestedTheme="Dark">
           <Application.Resources>
             <ResourceDictionary>
               <ResourceDictionary.MergedDictionaries>
                 <ResourceDictionary Source="/Themes/Zune.xaml"/>
               </ResourceDictionary.MergedDictionaries>
             </ResourceDictionary>
           </Application.Resources>
         </Application>

  3. Reference styles in pages:

         <TextBlock Style="{StaticResource ZunePageTitle}" Text="clipboard"/>
         <Button    Style="{StaticResource ZuneButtonPrimary}" Content="save"/>

  DESIGN RULES (do not deviate)
  =============================
  - Background is always #000000. No gradients, no surfaces above #1C1C1C.
  - One accent: Zune orange #EB7100. Use sparingly — voice, never decoration.
  - All headers lowercase. Authored in lowercase; styles enforce weight only.
  - Large titles bleed off the right edge (negative right margin). That's the move.
  - No rounded corners anywhere. CornerRadius = 0.
  - No drop shadows. Depth comes from absence of decoration.
  - Border thickness is 2px. Never 1px (except hairline dividers).
  - Type: Segoe UI Light for big stuff, Segoe UI Regular for body.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ============================================================
       1. RAW COLORS
       ============================================================ -->
  <Color x:Key="ZuneBlackColor">#FF000000</Color>
  <Color x:Key="ZuneWhiteColor">#FFFFFFFF</Color>
  <Color x:Key="ZuneOrangeColor">#FFEB7100</Color>
  <Color x:Key="ZuneOrangeHotColor">#FFFF8A1F</Color>
  <Color x:Key="ZuneOrangeDeepColor">#FFB85700</Color>
  <Color x:Key="ZuneDangerColor">#FFE51400</Color>

  <!-- ============================================================
       2. BRUSHES
       ============================================================ -->

  <!-- Surfaces -->
  <SolidColorBrush x:Key="ZuneBackground"  Color="#FF000000"/>
  <SolidColorBrush x:Key="ZuneSurface1"    Color="#FF0A0A0A"/>
  <SolidColorBrush x:Key="ZuneSurface2"    Color="#FF141414"/>
  <SolidColorBrush x:Key="ZuneSurface3"    Color="#FF1C1C1C"/>
  <SolidColorBrush x:Key="ZuneLine"        Color="#FF2A2A2A"/>
  <SolidColorBrush x:Key="ZuneLineStrong"  Color="#FF3D3D3D"/>

  <!-- Foreground (text) -->
  <SolidColorBrush x:Key="ZuneForeground"  Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="ZuneForeground2" Color="#FFB8B8B8"/>
  <SolidColorBrush x:Key="ZuneForeground3" Color="#FF7A7A7A"/>
  <SolidColorBrush x:Key="ZuneForeground4" Color="#FF555555"/>
  <SolidColorBrush x:Key="ZuneForeground5" Color="#FF333333"/>

  <!-- The one accent -->
  <SolidColorBrush x:Key="ZuneAccent"      Color="#FFEB7100"/>
  <SolidColorBrush x:Key="ZuneAccentHot"   Color="#FFFF8A1F"/>
  <SolidColorBrush x:Key="ZuneAccentDeep"  Color="#FFB85700"/>

  <!-- Semantic (use sparingly) -->
  <SolidColorBrush x:Key="ZuneDanger"      Color="#FFE51400"/>

  <!-- ============================================================
       3. METRICS
       ============================================================ -->
  <x:Double x:Key="ZuneSpaceXS">4</x:Double>
  <x:Double x:Key="ZuneSpaceS">8</x:Double>
  <x:Double x:Key="ZuneSpaceM">12</x:Double>
  <x:Double x:Key="ZuneSpaceL">16</x:Double>
  <x:Double x:Key="ZuneSpaceXL">24</x:Double>
  <x:Double x:Key="ZuneSpace2XL">32</x:Double>
  <x:Double x:Key="ZuneSpace3XL">48</x:Double>   <!-- page gutter -->
  <x:Double x:Key="ZuneSpace4XL">64</x:Double>
  <x:Double x:Key="ZuneSpace5XL">96</x:Double>   <!-- title breathing room -->
  <x:Double x:Key="ZuneSpace6XL">144</x:Double>

  <Thickness    x:Key="ZunePageGutter">48,0,48,0</Thickness>
  <Thickness    x:Key="ZuneBorderThickness">2</Thickness>
  <CornerRadius x:Key="ZuneCornerRadius">0</CornerRadius>

  <!-- ============================================================
       4. TEXT STYLES
       ============================================================ -->

  <!-- Bleed title — pivot-level header. Negative right margin lets it run off the canvas. -->
  <Style x:Key="ZuneTitleBleed" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="200"/>
    <Setter Property="LineHeight" Value="170"/>
    <Setter Property="CharacterSpacing" Value="-40"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="TextWrapping" Value="NoWrap"/>
    <Setter Property="Margin" Value="40,0,-200,0"/>
  </Style>

  <Style x:Key="ZunePageTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="96"/>
    <Setter Property="CharacterSpacing" Value="-30"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
  </Style>

  <Style x:Key="ZuneSubhead" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="48"/>
    <Setter Property="CharacterSpacing" Value="-20"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
  </Style>

  <Style x:Key="ZunePivotHeader" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="44"/>
    <Setter Property="CharacterSpacing" Value="-20"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground4}"/>
  </Style>

  <Style x:Key="ZuneListItem" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="22"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
  </Style>

  <Style x:Key="ZuneBody" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="15"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground2}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="ZuneCaption" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="12"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground3}"/>
  </Style>

  <!-- Eyebrow — the ONLY uppercase use. Author content as UPPERCASE in the Text= value. -->
  <Style x:Key="ZuneEyebrow" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="FontSize"   Value="11"/>
    <Setter Property="CharacterSpacing" Value="180"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground3}"/>
  </Style>

  <!-- ============================================================
       5. BUTTONS
       ============================================================ -->

  <!-- Primary — filled accent -->
  <Style x:Key="ZuneButtonPrimary" TargetType="Button">
    <Setter Property="Background"      Value="{StaticResource ZuneAccent}"/>
    <Setter Property="Foreground"      Value="{StaticResource ZuneForeground}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource ZuneAccent}"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="CornerRadius"    Value="0"/>
    <Setter Property="Padding"         Value="22,10"/>
    <Setter Property="FontFamily"      Value="Segoe UI"/>
    <Setter Property="FontSize"        Value="14"/>
    <Setter Property="HorizontalAlignment" Value="Left"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal"/>
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="Root.Background"  Value="{StaticResource ZuneAccentHot}"/>
                    <Setter Target="Root.BorderBrush" Value="{StaticResource ZuneAccentHot}"/>
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="Root.Background"  Value="{StaticResource ZuneAccentDeep}"/>
                    <Setter Target="Root.BorderBrush" Value="{StaticResource ZuneAccentDeep}"/>
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="Root.Background"  Value="Transparent"/>
                    <Setter Target="Root.BorderBrush" Value="{StaticResource ZuneForeground5}"/>
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Secondary — white outline, transparent fill -->
  <Style x:Key="ZuneButton" TargetType="Button" BasedOn="{StaticResource ZuneButtonPrimary}">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{StaticResource ZuneForeground}"/>
  </Style>

  <!-- Ghost — text only -->
  <Style x:Key="ZuneButtonGhost" TargetType="Button" BasedOn="{StaticResource ZuneButtonPrimary}">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground"  Value="{StaticResource ZuneForeground2}"/>
  </Style>

  <!-- Danger — red fill. Use only for destructive primary actions. -->
  <Style x:Key="ZuneButtonDanger" TargetType="Button" BasedOn="{StaticResource ZuneButtonPrimary}">
    <Setter Property="Background"  Value="{StaticResource ZuneDanger}"/>
    <Setter Property="BorderBrush" Value="{StaticResource ZuneDanger}"/>
  </Style>

  <!-- ============================================================
       6. TEXT BOX
       ============================================================ -->
  <Style x:Key="ZuneTextBox" TargetType="TextBox">
    <Setter Property="Background"              Value="Transparent"/>
    <Setter Property="Foreground"              Value="{StaticResource ZuneForeground}"/>
    <Setter Property="BorderBrush"             Value="{StaticResource ZuneForeground}"/>
    <Setter Property="BorderThickness"         Value="2"/>
    <Setter Property="CornerRadius"            Value="0"/>
    <Setter Property="Padding"                 Value="14,10"/>
    <Setter Property="FontFamily"              Value="Segoe UI"/>
    <Setter Property="FontSize"                Value="16"/>
    <Setter Property="SelectionHighlightColor" Value="{StaticResource ZuneAccent}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Grid>
            <Border x:Name="BorderElement"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ScrollViewer x:Name="ContentElement"
                            Padding="{TemplateBinding Padding}"
                            IsTabStop="False"/>
            </Border>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal"/>
                <VisualState x:Name="Focused">
                  <VisualState.Setters>
                    <Setter Target="BorderElement.BorderBrush" Value="{StaticResource ZuneAccent}"/>
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       7. TOGGLE SWITCH — the iconic Zune slider
       Rectangular track, 2px border, chunky vertical thumb that snaps.
       On = accent fill. Off = transparent with gray border.
       ============================================================ -->
  <Style x:Key="ZuneToggleSwitch" TargetType="ToggleSwitch">
    <Setter Property="OnContent"  Value="on"/>
    <Setter Property="OffContent" Value="off"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="MinWidth"   Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleSwitch">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Header sits on the LEFT, not above -->
            <ContentPresenter Grid.Column="0"
                              Content="{TemplateBinding Header}"
                              Foreground="{StaticResource ZuneForeground2}"
                              VerticalAlignment="Center"/>

            <!-- on/off label between header and track -->
            <TextBlock x:Name="StateText" Grid.Column="1"
                       Margin="0,0,10,0" VerticalAlignment="Center"
                       Text="off" Foreground="{StaticResource ZuneForeground3}"/>

            <!-- Track -->
            <Border x:Name="Track" Grid.Column="2"
                    Width="90" Height="28"
                    BorderBrush="{StaticResource ZuneForeground3}"
                    BorderThickness="2"
                    Background="Transparent">
              <Canvas>
                <Border x:Name="Thumb"
                        Width="14" Height="28"
                        Canvas.Left="-2" Canvas.Top="-2"
                        Background="{StaticResource ZuneForeground}"/>
              </Canvas>
            </Border>

            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="ToggleStates">
                <VisualState x:Name="Off"/>
                <VisualState x:Name="On">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Thumb"
                                     Storyboard.TargetProperty="(Canvas.Left)"
                                     To="78" Duration="0:0:0.26">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ColorAnimation Storyboard.TargetName="Track"
                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                    To="#FFEB7100" Duration="0:0:0.22"/>
                    <ColorAnimation Storyboard.TargetName="Track"
                                    Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                    To="#FFEB7100" Duration="0:0:0.22"/>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="StateText"
                                                   Storyboard.TargetProperty="Text">
                      <DiscreteObjectKeyFrame KeyTime="0" Value="on"/>
                    </ObjectAnimationUsingKeyFrames>
                  </Storyboard>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       8. LIST VIEW — settings-style rows, no dividers, no chrome
       ============================================================ -->
  <Style x:Key="ZuneListView" TargetType="ListView">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="ItemContainerStyle">
      <Setter.Value>
        <Style TargetType="ListViewItem">
          <Setter Property="Padding"     Value="0"/>
          <Setter Property="Margin"      Value="0"/>
          <Setter Property="MinHeight"   Value="0"/>
          <Setter Property="Background"  Value="Transparent"/>
          <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListViewItem">
                <Grid x:Name="Root" Background="Transparent">
                  <ContentPresenter/>
                  <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="CommonStates">
                      <VisualState x:Name="Normal"/>
                      <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                          <Setter Target="Root.Background" Value="{StaticResource ZuneSurface1}"/>
                        </VisualState.Setters>
                      </VisualState>
                      <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                          <Setter Target="Root.Background" Value="{StaticResource ZuneSurface3}"/>
                        </VisualState.Setters>
                      </VisualState>
                      <VisualState x:Name="Selected">
                        <VisualState.Setters>
                          <Setter Target="Root.Background" Value="{StaticResource ZuneSurface3}"/>
                        </VisualState.Setters>
                      </VisualState>
                    </VisualStateGroup>
                  </VisualStateManager.VisualStateGroups>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Use this DataTemplate (or fork it) for settings-style list rows -->
  <DataTemplate x:Key="ZuneListItemTemplate">
    <StackPanel Margin="0,14,0,14" Spacing="4">
      <TextBlock Text="{Binding Label}"    Style="{StaticResource ZuneListItem}"/>
      <TextBlock Text="{Binding SubLabel}" Style="{StaticResource ZuneCaption}"/>
    </StackPanel>
  </DataTemplate>

  <!-- ============================================================
       9. PIVOT — twist navigation
       ============================================================ -->
  <Style x:Key="ZunePivot" TargetType="Pivot">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="HeaderTemplate">
      <Setter.Value>
        <DataTemplate>
          <TextBlock Text="{Binding}"
                     FontFamily="Segoe UI Light"
                     FontWeight="Light"
                     FontSize="44"
                     CharacterSpacing="-20"
                     Margin="0,0,28,8"/>
        </DataTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       10. SLIDER — vertical-bar thumb, 2px track
       ============================================================ -->
  <Style x:Key="ZuneSlider" TargetType="Slider">
    <Setter Property="Foreground" Value="{StaticResource ZuneAccent}"/>
    <Setter Property="Background" Value="{StaticResource ZuneForeground5}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid Height="24">
            <Rectangle Height="2" Fill="{TemplateBinding Background}" VerticalAlignment="Center"/>
            <Rectangle x:Name="HorizontalDecreaseRect"
                       Height="2" Fill="{TemplateBinding Foreground}"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Thumb x:Name="HorizontalThumb" Width="8" Height="24">
              <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                  <Rectangle Fill="{StaticResource ZuneForeground}" Width="8" Height="24"/>
                </ControlTemplate>
              </Thumb.Template>
            </Thumb>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       11. CONTENT DIALOG — full-bleed feel
       ============================================================ -->
  <Style x:Key="ZuneContentDialog" TargetType="ContentDialog">
    <Setter Property="Background"      Value="{StaticResource ZuneBackground}"/>
    <Setter Property="Foreground"      Value="{StaticResource ZuneForeground}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource ZuneLine}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="0"/>
    <Setter Property="MaxWidth"        Value="640"/>
    <Setter Property="Padding"         Value="24"/>
    <Setter Property="TitleTemplate">
      <Setter.Value>
        <DataTemplate>
          <TextBlock Text="{Binding}"
                     FontFamily="Segoe UI Light"
                     FontWeight="Light"
                     FontSize="56"
                     CharacterSpacing="-30"/>
        </DataTemplate>
      </Setter.Value>
    </Setter>
    <Setter Property="PrimaryButtonStyle"   Value="{StaticResource ZuneButtonPrimary}"/>
    <Setter Property="SecondaryButtonStyle" Value="{StaticResource ZuneButton}"/>
  </Style>

  <!-- ============================================================
       12. MENU FLYOUT
       ============================================================ -->
  <Style x:Key="ZuneMenuFlyoutPresenter" TargetType="MenuFlyoutPresenter">
    <Setter Property="Background"      Value="{StaticResource ZuneBackground}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource ZuneLine}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="0"/>
    <Setter Property="Padding"         Value="0,6,0,6"/>
  </Style>

  <Style x:Key="ZuneMenuFlyoutItem" TargetType="MenuFlyoutItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="Padding"    Value="18,10"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuFlyoutItem">
          <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}"
                Padding="{TemplateBinding Padding}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{TemplateBinding Text}"
                       Foreground="{TemplateBinding Foreground}"/>
            <TextBlock Grid.Column="1" Text="{TemplateBinding KeyboardAcceleratorTextOverride}"
                       Foreground="{StaticResource ZuneForeground3}"
                       FontSize="12"/>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal"/>
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="LayoutRoot.Background" Value="{StaticResource ZuneSurface2}"/>
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       13. SCROLL BAR — minimal sliver, hover-revealed
       ============================================================ -->
  <Style x:Key="ZuneScrollBar" TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="MinWidth"   Value="6"/>
    <Setter Property="MinHeight"  Value="6"/>
  </Style>

  <!-- ============================================================
       14. PAGE-ENTER STORYBOARD
       Apply to a Page's root Grid on Loaded for the parallax twist feel.
       ============================================================ -->
  <Storyboard x:Key="ZunePageEnter">
    <DoubleAnimation
        Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)"
        From="80" To="0" Duration="0:0:0.65">
      <DoubleAnimation.EasingFunction>
        <CubicEase EasingMode="EaseOut"/>
      </DoubleAnimation.EasingFunction>
    </DoubleAnimation>
    <DoubleAnimation
        Storyboard.TargetProperty="Opacity"
        From="0" To="1" Duration="0:0:0.4"/>
  </Storyboard>

</ResourceDictionary>
