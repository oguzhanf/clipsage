<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ClipSage.App.PortableUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipSage.App"
        mc:Ignorable="d"
        Title="clipsage / update"
        MinHeight="440" MinWidth="600"
        Width="680" Height="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ZuneWindow}">

    <Grid Margin="48,32,48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title. -->
        <TextBlock Grid.Row="0"
                   FontFamily="Segoe UI Light" FontWeight="Light"
                   FontSize="56"
                   Foreground="{StaticResource ZuneForeground}"
                   Text="check for updates"
                   Margin="0,0,-200,20"/>

        <!-- Progress. -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="1"
                     Style="{StaticResource ZuneProgressBar}"
                     IsIndeterminate="True"
                     Margin="0,0,0,20"/>

        <!-- Status block. -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock x:Name="StatusTextBlock"
                       Text="checking for updates..."
                       Foreground="{StaticResource ZuneForeground}"
                       FontFamily="Segoe UI Light" FontWeight="Light" FontSize="22"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="VersionTextBlock"
                       Foreground="{StaticResource ZuneAccent}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"
                       Visibility="Collapsed"/>
            <TextBlock x:Name="ReleaseDateTextBlock"
                       Style="{StaticResource ZuneCaption}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- Log. -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource ZuneLine}"
                BorderThickness="0,1,0,1"
                Background="{StaticResource ZuneSurface1}"
                Margin="0,0,0,20">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource ZuneForeground2}"
                         FontFamily="Consolas"
                         FontSize="12"
                         Padding="16"
                         MinHeight="120"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons. -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <CheckBox x:Name="AutoUpdateCheckBox"
                      Style="{StaticResource ZuneCheckBox}"
                      Content="check for updates automatically"
                      IsChecked="True"
                      VerticalAlignment="Center"
                      Margin="0,0,20,0"/>
            <Button x:Name="UpdateButton"
                    Style="{StaticResource ZuneButtonPrimary}"
                    Content="update now"
                    Padding="22,10"
                    Margin="0,0,12,0"
                    IsEnabled="False"
                    Click="UpdateButton_Click"/>
            <Button x:Name="CloseButton"
                    Style="{StaticResource ZuneButton}"
                    Content="close"
                    Padding="22,10"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
