<Window x:Class="ClipSage.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipSage.App"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:ClipSage.App.Converters"
        mc:Ignorable="d"
        Title="clipsage"
        Height="640" Width="1100"
        MinHeight="420" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Style="{StaticResource ZuneWindow}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Tray menu (consumed in code-behind by Resources["TrayMenu"]) -->
        <ContextMenu x:Key="TrayMenu"
                     Background="{StaticResource ZuneBackground}"
                     BorderBrush="{StaticResource ZuneLine}"
                     BorderThickness="1"
                     Foreground="{StaticResource ZuneForeground}">
            <MenuItem Header="show window" Click="ShowWindow_Click"/>
            <MenuItem Header="settings..." Click="Settings_Click"/>
            <Separator Background="{StaticResource ZuneLine}"/>
            <MenuItem Header="exit" Click="Exit_Click"/>
        </ContextMenu>

        <!-- Local converters (also declared in App.xaml; kept here because PreviewPane resources need them) -->
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:NullToBooleanConverter x:Key="NullToBooleanConverter" />
        <converters:DataTypeToColorConverter x:Key="DataTypeToColorConverter" />
        <converters:DataTypeToIconConverter x:Key="DataTypeToIconConverter" />
        <converters:DataTypeToLabelConverter x:Key="DataTypeToLabelConverter" />
        <converters:BooleanToMonitoringTextConverter x:Key="BooleanToMonitoringTextConverter" />
        <converters:DataTypeToTextVisibilityConverter x:Key="DataTypeToTextVisibilityConverter" />
        <converters:DataTypeToImageVisibilityConverter x:Key="DataTypeToImageVisibilityConverter" />
        <converters:DataTypeToFileVisibilityConverter x:Key="DataTypeToFileVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>    <!-- chrome bar -->
            <RowDefinition Height="Auto"/>  <!-- menu -->
            <RowDefinition Height="Auto"/>  <!-- title -->
            <RowDefinition Height="Auto"/>  <!-- search -->
            <RowDefinition Height="*"/>     <!-- list + preview -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- Custom chrome bar (replaces the Windows title bar). -->
        <Grid Grid.Row="0" Background="{StaticResource ZuneBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Wordmark (small, on the left). Whole strip is draggable. -->
            <TextBlock Grid.Column="0"
                       Text="clipsage"
                       Foreground="{StaticResource ZuneForeground4}"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>

            <!-- Min / Max / Close — IsHitTestVisibleInChrome lets them receive clicks. -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource ZuneChromeButton}"
                        Content="&#xE921;"
                        ToolTip="minimize"
                        Click="MinimizeButton_Click"/>
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource ZuneChromeButton}"
                        Content="&#xE922;"
                        ToolTip="maximize"
                        Click="MaximizeButton_Click"/>
                <Button x:Name="CloseButton"
                        Style="{StaticResource ZuneChromeCloseButton}"
                        Content="&#xE8BB;"
                        ToolTip="close"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Menu — flat, lowercase. -->
        <Menu Grid.Row="1" Style="{StaticResource ZuneMenu}" Padding="32,8,32,0">
            <MenuItem Header="file" Foreground="{StaticResource ZuneForeground2}">
                <MenuItem Header="settings..." Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="help" Foreground="{StaticResource ZuneForeground2}">
                <MenuItem Header="about" Click="About_Click"/>
                <MenuItem Header="check for updates" Click="CheckForUpdates_Click"/>
            </MenuItem>
        </Menu>

        <!-- Title — big, lowercase, light, the signature Zune move. -->
        <Grid Grid.Row="2" Margin="32,16,0,8">
            <TextBlock FontFamily="Segoe UI Light"
                       FontWeight="Light"
                       FontSize="72"
                       Foreground="{StaticResource ZuneForeground}"
                       Margin="0,0,-200,0">
                <Run Text="clipboard"/><Run Text="  history" Foreground="{StaticResource ZuneForeground5}"/>
            </TextBlock>
        </Grid>

        <!-- Search box. -->
        <Grid Grid.Row="3" Margin="32,8,32,16">
            <TextBox x:Name="SearchBox"
                     Style="{StaticResource ZuneTextBox}"
                     FontSize="14"
                     Padding="14,8"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="type to filter clipboard..."/>
        </Grid>

        <!-- List + preview. -->
        <Grid Grid.Row="4" Margin="32,0,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: clipboard history list. -->
            <DockPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock DockPanel.Dock="Top"
                           Style="{StaticResource ZuneEyebrow}"
                           Text="HISTORY"
                           Margin="0,0,0,8"/>

                <ListView x:Name="ClipboardList"
                          Style="{StaticResource ZuneListView}"
                          ItemsSource="{Binding ClipboardEntries}"
                          SelectedItem="{Binding SelectedEntry}"
                          VirtualizingPanel.ScrollUnit="Pixel">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Thumb/type swatch. -->
                                <Border Grid.Column="0" Width="44" Height="44"
                                        Background="{StaticResource ZuneSurface2}"
                                        BorderBrush="{Binding DataType, Converter={StaticResource DataTypeToColorConverter}}"
                                        BorderThickness="2"
                                        HorizontalAlignment="Left">
                                    <Grid>
                                        <!-- Default letter mark when no thumbnail. -->
                                        <Grid Visibility="{Binding ThumbnailImage, Converter={StaticResource NullToBooleanConverter}, ConverterParameter=Inverse}">
                                            <TextBlock Text="T"
                                                       FontFamily="Segoe UI Light" FontWeight="Light"
                                                       FontSize="22"
                                                       Foreground="{StaticResource ZuneForeground}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding DataType, Converter={StaticResource DataTypeToTextVisibilityConverter}}"/>
                                            <TextBlock Text="I"
                                                       FontFamily="Segoe UI Light" FontWeight="Light"
                                                       FontSize="22"
                                                       Foreground="{StaticResource ZuneForeground}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding DataType, Converter={StaticResource DataTypeToImageVisibilityConverter}}"/>
                                            <TextBlock Text="F"
                                                       FontFamily="Segoe UI Light" FontWeight="Light"
                                                       FontSize="22"
                                                       Foreground="{StaticResource ZuneForeground}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding DataType, Converter={StaticResource DataTypeToFileVisibilityConverter}}"/>
                                        </Grid>
                                        <Image Source="{Binding ThumbnailImage}"
                                               Stretch="UniformToFill"
                                               Visibility="{Binding DataType, Converter={StaticResource DataTypeToImageVisibilityConverter}}"/>
                                    </Grid>
                                </Border>

                                <!-- Text. -->
                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayText}"
                                               FontFamily="Segoe UI"
                                               FontSize="14"
                                               Foreground="{StaticResource ZuneForeground}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:g}'}"
                                                   Style="{StaticResource ZuneCaption}"/>
                                        <TextBlock Text="  ·  "
                                                   Style="{StaticResource ZuneCaption}"
                                                   Foreground="{StaticResource ZuneForeground4}"
                                                   Visibility="{Binding ComputerName, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                        <TextBlock Text="{Binding FormattedComputerName}"
                                                   Visibility="{Binding ComputerName, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource ZuneCaption}">
                                                    <Style.Triggers>
                                                        <!-- Remote machines: accent. Local: muted. -->
                                                        <DataTrigger Binding="{Binding ComputerName}" Value="{x:Static sys:Environment.MachineName}">
                                                            <Setter Property="Foreground" Value="{StaticResource ZuneForeground3}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Foreground" Value="{StaticResource ZuneAccent}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <Grid.ToolTip>
                                    <ToolTip Background="{StaticResource ZuneBackground}"
                                             BorderBrush="{StaticResource ZuneLine}"
                                             BorderThickness="1">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding DisplayText}"
                                                       Foreground="{StaticResource ZuneForeground}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='time: {0:g}'}"
                                                       Foreground="{StaticResource ZuneForeground2}"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding ComputerName, StringFormat='computer: {0}'}"
                                                       Foreground="{StaticResource ZuneForeground2}"
                                                       FontSize="12"
                                                       Visibility="{Binding ComputerName, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                            <TextBlock Text="{Binding SourceFile, StringFormat='source: {0}'}"
                                                       Foreground="{StaticResource ZuneForeground2}"
                                                       FontSize="12"
                                                       Visibility="{Binding SourceFile, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Grid.ToolTip>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>

            <!-- Hairline divider — depth comes from absence of decoration. -->
            <Border Grid.Column="1" Width="1" Background="{StaticResource ZuneLine}" Margin="0,4"/>

            <!-- RIGHT: preview pane + actions. -->
            <DockPanel Grid.Column="2" Margin="24,0,0,0">
                <TextBlock DockPanel.Dock="Top"
                           Style="{StaticResource ZuneEyebrow}"
                           Text="PREVIEW"
                           Margin="0,0,0,12"/>

                <!-- Actions at bottom-right. -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,8">
                    <Button Content="copy"
                            Style="{StaticResource ZuneButtonPrimary}"
                            Margin="0,0,12,0"
                            Click="CopyButton_Click"
                            IsEnabled="{Binding SelectedEntry, Converter={StaticResource NullToBooleanConverter}}"/>
                    <Button Content="pin"
                            Style="{StaticResource ZuneButton}"
                            Margin="0,0,12,0"
                            Click="PinButton_Click"
                            IsEnabled="{Binding SelectedEntry, Converter={StaticResource NullToBooleanConverter}}"/>
                    <Button Content="delete"
                            Style="{StaticResource ZuneButtonGhost}"
                            Click="DeleteButton_Click"
                            IsEnabled="{Binding SelectedEntry, Converter={StaticResource NullToBooleanConverter}}"/>
                </StackPanel>

                <!-- Preview content. -->
                <ContentControl x:Name="PreviewPane">
                    <ContentControl.Resources>
                        <!-- Selected item metadata card. -->
                        <DataTemplate x:Key="DetailsCardTemplate">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{Binding ContentTypeDescription}"
                                           Style="{StaticResource ZuneEyebrow}"
                                           Foreground="{StaticResource ZuneAccent}"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="date"
                                               Style="{StaticResource ZuneCaption}" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Timestamp, StringFormat='{}{0:f}'}"
                                               Foreground="{StaticResource ZuneForeground2}"
                                               FontSize="13" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="source"
                                               Style="{StaticResource ZuneCaption}" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding FormattedComputerName}"
                                               Foreground="{StaticResource ZuneForeground2}"
                                               FontSize="13" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="age"
                                               Style="{StaticResource ZuneCaption}" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding ItemAge}"
                                               Foreground="{StaticResource ZuneForeground2}"
                                               FontSize="13"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate x:Key="TextPreviewTemplate">
                            <DockPanel>
                                <ContentControl DockPanel.Dock="Top"
                                                ContentTemplate="{StaticResource DetailsCardTemplate}"
                                                Content="{Binding}"/>
                                <Border BorderBrush="{StaticResource ZuneLine}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <TextBox Text="{Binding PlainText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{StaticResource ZuneForeground}"
                                                 CaretBrush="{StaticResource ZuneAccent}"
                                                 SelectionBrush="{StaticResource ZuneAccent}"
                                                 FontSize="14"/>
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </DataTemplate>

                        <DataTemplate x:Key="ImagePreviewTemplate">
                            <DockPanel>
                                <ContentControl DockPanel.Dock="Top"
                                                ContentTemplate="{StaticResource DetailsCardTemplate}"
                                                Content="{Binding}"/>
                                <Border BorderBrush="{StaticResource ZuneLine}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <Image Source="{Binding ImageSource}"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </DataTemplate>

                        <DataTemplate x:Key="EmptyPreviewTemplate">
                            <TextBlock Text="select an item to preview"
                                       Style="{StaticResource ZuneCaption}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </DockPanel>
        </Grid>

        <!-- Status bar. -->
        <Border Grid.Row="5" BorderBrush="{StaticResource ZuneLine}" BorderThickness="0,1,0,0" Margin="0,16,0,0">
            <StatusBar Style="{StaticResource ZuneStatusBar}" Height="36" Padding="32,0">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>

                <StatusBarItem Grid.Column="0">
                    <TextBlock Text="{Binding MonitoringStatusText}"
                               Foreground="{StaticResource ZuneForeground3}"
                               Margin="0,0,16,0"/>
                </StatusBarItem>

                <StatusBarItem Grid.Column="1">
                    <TextBlock Text="{Binding EventStatusText}"
                               Foreground="{StaticResource ZuneAccent}"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0"/>
                </StatusBarItem>

                <StatusBarItem Grid.Column="2">
                    <TextBlock Text="{Binding UpdateStatusText}"
                               Foreground="{StaticResource ZuneForeground3}"/>
                </StatusBarItem>

                <StatusBarItem Grid.Column="3">
                    <TextBlock x:Name="VersionText"
                               Foreground="{StaticResource ZuneForeground4}"
                               Margin="0,0,16,0"/>
                </StatusBarItem>

                <StatusBarItem Grid.Column="4">
                    <ToggleButton x:Name="MonitoringToggle"
                                  Style="{StaticResource ZuneToggleSwitch}"
                                  IsChecked="{Binding IsMonitoring, Mode=OneWay}"
                                  Click="MonitoringToggle_Click"
                                  Content="monitoring"/>
                </StatusBarItem>
            </StatusBar>
        </Border>
    </Grid>
</Window>
