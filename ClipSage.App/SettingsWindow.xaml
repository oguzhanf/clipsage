<Window x:Class="ClipSage.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipSage.App"
        mc:Ignorable="d"
        Title="clipsage / settings"
        MinHeight="560" MinWidth="640"
        Height="700" Width="720"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource ZuneWindow}">

    <Grid Margin="48,32,48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title — bleed off right edge. -->
        <TextBlock Grid.Row="0"
                   FontFamily="Segoe UI Light" FontWeight="Light"
                   FontSize="72"
                   Foreground="{StaticResource ZuneForeground}"
                   Text="settings"
                   Margin="0,0,-200,24"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- GENERAL ============================================ -->
                <TextBlock Style="{StaticResource ZuneEyebrow}" Text="GENERAL" Margin="0,0,0,16"/>

                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="start with windows"
                              IsChecked="{Binding StartWithWindows}"
                              Margin="0,0,0,18"/>
                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="start minimized to tray"
                              IsChecked="{Binding StartMinimized}"
                              Margin="0,0,0,18"/>
                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="minimize to tray when closed"
                              IsChecked="{Binding MinimizeToTray}"
                              Margin="0,0,0,32"/>

                <!-- CLIPBOARD ========================================== -->
                <TextBlock Style="{StaticResource ZuneEyebrow}" Text="CLIPBOARD HISTORY" Margin="0,0,0,16"/>

                <StackPanel Margin="0,0,0,18">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="maximum history size"
                                   Foreground="{StaticResource ZuneForeground2}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MaxHistorySize, StringFormat='{}{0:N0}'}"
                                   Foreground="{StaticResource ZuneAccent}"
                                   FontFamily="Segoe UI Light" FontWeight="Light" FontSize="22"/>
                    </Grid>
                    <Slider Style="{StaticResource ZuneSlider}"
                            Value="{Binding MaxHistorySize}" Minimum="10" Maximum="1000"/>
                </StackPanel>

                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="ignore duplicate entries"
                              IsChecked="{Binding IgnoreDuplicates}"
                              Margin="0,0,0,18"/>

                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="truncate large text entries"
                              IsChecked="{Binding TruncateLargeText}"
                              Margin="0,0,0,8"/>
                <StackPanel Margin="24,0,0,18" IsEnabled="{Binding TruncateLargeText}">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="maximum text length (KB)"
                                   Foreground="{StaticResource ZuneForeground2}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MaxTextLength, StringFormat='{}{0:N0}'}"
                                   Foreground="{StaticResource ZuneAccent}"
                                   FontFamily="Segoe UI Light" FontWeight="Light" FontSize="22"/>
                    </Grid>
                    <Slider Style="{StaticResource ZuneSlider}"
                            Value="{Binding MaxTextLength}" Minimum="1" Maximum="1000"/>
                </StackPanel>

                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="ignore large images"
                              IsChecked="{Binding IgnoreLargeImages}"
                              Margin="0,0,0,8"/>
                <StackPanel Margin="24,0,0,32" IsEnabled="{Binding IgnoreLargeImages}">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="maximum image size (MB)"
                                   Foreground="{StaticResource ZuneForeground2}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MaxImageSize, StringFormat='{}{0:N0}'}"
                                   Foreground="{StaticResource ZuneAccent}"
                                   FontFamily="Segoe UI Light" FontWeight="Light" FontSize="22"/>
                    </Grid>
                    <Slider Style="{StaticResource ZuneSlider}"
                            Value="{Binding MaxImageSize}" Minimum="1" Maximum="100"/>
                </StackPanel>

                <!-- CACHING ============================================ -->
                <TextBlock Style="{StaticResource ZuneEyebrow}" Text="CACHING" Margin="0,0,0,16"/>

                <TextBlock Text="caching folder"
                           Foreground="{StaticResource ZuneForeground2}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CachingFolderTextBox" Grid.Column="0"
                             Style="{StaticResource ZuneTextBox}"
                             FontSize="14" Padding="14,8"
                             Margin="0,0,12,0"
                             Text="{Binding CachingFolder, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="CachingFolderTextBox_TextChanged"
                             ToolTip="enter a folder path or use the browse button"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource ZuneButton}"
                            Content="browse"
                            Padding="18,8"
                            Click="BrowseCachingFolder_Click"/>
                </Grid>
                <TextBlock Style="{StaticResource ZuneCaption}"
                           Text="tip: use a folder in onedrive, google drive, or dropbox to sync clipboard data across systems."
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="CachingFolderWarning"
                           Foreground="{StaticResource ZuneDanger}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,0,0,16"/>

                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="cache copied files (stores file paths by default)"
                              IsChecked="{Binding CacheFiles}"
                              Margin="0,0,0,8"
                              ToolTip="when off, only file paths are stored. when on, files are copied to the cache folder."/>

                <StackPanel Margin="24,0,0,16" IsEnabled="{Binding CacheFiles}">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="maximum file cache size (MB)"
                                   Foreground="{StaticResource ZuneForeground2}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MaxFileCacheSize, StringFormat='{}{0:N0}'}"
                                   Foreground="{StaticResource ZuneAccent}"
                                   FontFamily="Segoe UI Light" FontWeight="Light" FontSize="22"/>
                    </Grid>
                    <Slider Style="{StaticResource ZuneSlider}"
                            Value="{Binding MaxFileCacheSize}" Minimum="1" Maximum="1000"/>
                </StackPanel>

                <TextBlock Style="{StaticResource ZuneCaption}"
                           Text="note: large file sets are not cached automatically — only their paths are stored."
                           TextWrapping="Wrap"
                           Margin="0,0,0,32"/>

                <!-- HOTKEYS ============================================ -->
                <TextBlock Style="{StaticResource ZuneEyebrow}" Text="HOTKEYS" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="quick picker"
                               Foreground="{StaticResource ZuneForeground2}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="Ctrl+Shift+V"
                             Style="{StaticResource ZuneTextBox}"
                             IsReadOnly="True"
                             Width="180" FontSize="14" Padding="14,8"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- UPDATES ============================================ -->
                <TextBlock Style="{StaticResource ZuneEyebrow}" Text="UPDATES" Margin="0,0,0,16"/>
                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="automatically check for updates"
                              IsChecked="{Binding CheckForUpdates}"
                              Margin="0,0,0,18"/>
                <ToggleButton Style="{StaticResource ZuneToggleSwitch}"
                              Content="automatically install updates"
                              IsChecked="{Binding AutoInstallUpdates}"
                              IsEnabled="{Binding CheckForUpdates}"
                              Margin="24,0,0,18"/>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                    <Button Style="{StaticResource ZuneButton}"
                            Content="check now"
                            Padding="22,10"
                            Click="CheckForUpdates_Click"/>
                    <TextBlock x:Name="LastUpdateCheckText"
                               Text="last checked: never"
                               Foreground="{StaticResource ZuneForeground3}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="UpdateStatusText"
                           Foreground="{StaticResource ZuneForeground2}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Cancel / save. -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Style="{StaticResource ZuneButton}"
                    Content="cancel"
                    Padding="22,10"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"/>
            <Button Style="{StaticResource ZuneButtonPrimary}"
                    Content="save"
                    Padding="22,10"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
