<!--
  Zune.xaml — WPF port of the Zune HD design system.

  Adapted from /design/Themes/Zune.xaml (authored for WinUI 3). WPF differences:
    - <VisualState.Setters Target="X.Foo"> → <Style.Triggers> on IsMouseOver/IsPressed/etc.
    - No ToggleSwitch  → templated ToggleButton (ZuneToggleSwitch).
    - No Pivot         → templated TabControl/TabItem (ZuneTabControl/ZuneTabItem).
    - No ContentDialog → Window dialogs use ZuneWindow style.
    - No CharacterSpacing  → dropped (no WPF equivalent on TextBlock).
    - No StackPanel.Spacing → use per-child Margin.
    - x:Double         → sys:Double.

  Brush/style keys mirror the original so consumers reference {StaticResource ZuneFoo}.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- ============================================================
       1. COLORS
       ============================================================ -->
  <Color x:Key="ZuneBlackColor">#FF000000</Color>
  <Color x:Key="ZuneWhiteColor">#FFFFFFFF</Color>
  <Color x:Key="ZuneOrangeColor">#FFEB7100</Color>
  <Color x:Key="ZuneOrangeHotColor">#FFFF8A1F</Color>
  <Color x:Key="ZuneOrangeDeepColor">#FFB85700</Color>
  <Color x:Key="ZuneDangerColor">#FFE51400</Color>

  <!-- ============================================================
       2. BRUSHES
       ============================================================ -->
  <SolidColorBrush x:Key="ZuneBackground"  Color="#FF000000"/>
  <SolidColorBrush x:Key="ZuneSurface1"    Color="#FF0A0A0A"/>
  <SolidColorBrush x:Key="ZuneSurface2"    Color="#FF141414"/>
  <SolidColorBrush x:Key="ZuneSurface3"    Color="#FF1C1C1C"/>
  <SolidColorBrush x:Key="ZuneLine"        Color="#FF2A2A2A"/>
  <SolidColorBrush x:Key="ZuneLineStrong"  Color="#FF3D3D3D"/>

  <SolidColorBrush x:Key="ZuneForeground"  Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="ZuneForeground2" Color="#FFB8B8B8"/>
  <SolidColorBrush x:Key="ZuneForeground3" Color="#FF7A7A7A"/>
  <SolidColorBrush x:Key="ZuneForeground4" Color="#FF555555"/>
  <SolidColorBrush x:Key="ZuneForeground5" Color="#FF333333"/>

  <SolidColorBrush x:Key="ZuneAccent"      Color="#FFEB7100"/>
  <SolidColorBrush x:Key="ZuneAccentHot"   Color="#FFFF8A1F"/>
  <SolidColorBrush x:Key="ZuneAccentDeep"  Color="#FFB85700"/>

  <SolidColorBrush x:Key="ZuneDanger"      Color="#FFE51400"/>

  <!-- ============================================================
       3. METRICS
       ============================================================ -->
  <sys:Double x:Key="ZuneSpaceXS">4</sys:Double>
  <sys:Double x:Key="ZuneSpaceS">8</sys:Double>
  <sys:Double x:Key="ZuneSpaceM">12</sys:Double>
  <sys:Double x:Key="ZuneSpaceL">16</sys:Double>
  <sys:Double x:Key="ZuneSpaceXL">24</sys:Double>
  <sys:Double x:Key="ZuneSpace2XL">32</sys:Double>
  <sys:Double x:Key="ZuneSpace3XL">48</sys:Double>
  <sys:Double x:Key="ZuneSpace4XL">64</sys:Double>
  <sys:Double x:Key="ZuneSpace5XL">96</sys:Double>
  <sys:Double x:Key="ZuneSpace6XL">144</sys:Double>

  <Thickness    x:Key="ZunePageGutter">48,0,48,0</Thickness>
  <Thickness    x:Key="ZuneBorderThickness">2</Thickness>
  <CornerRadius x:Key="ZuneCornerRadius">0</CornerRadius>

  <!-- ============================================================
       4. TEXT STYLES
       ============================================================ -->
  <Style x:Key="ZuneTitleBleed" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="200"/>
    <Setter Property="LineHeight" Value="170"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="TextWrapping" Value="NoWrap"/>
    <Setter Property="Margin" Value="40,0,-200,0"/>
  </Style>

  <Style x:Key="ZunePageTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="96"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
  </Style>

  <Style x:Key="ZuneSubhead" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="48"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
  </Style>

  <Style x:Key="ZunePivotHeader" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Light"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="FontSize"   Value="44"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground4}"/>
  </Style>

  <Style x:Key="ZuneListItem" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="22"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
  </Style>

  <Style x:Key="ZuneBody" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="15"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground2}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="ZuneCaption" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="12"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground3}"/>
  </Style>

  <!-- Eyebrow — author text in UPPERCASE; tracking simulated via Typography.Capitals. -->
  <Style x:Key="ZuneEyebrow" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="FontSize"   Value="11"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground3}"/>
  </Style>

  <!-- ============================================================
       5. WINDOW BASE — black canvas
       ============================================================ -->
  <Style x:Key="ZuneWindow" TargetType="Window">
    <Setter Property="Background" Value="{StaticResource ZuneBackground}"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="13"/>
    <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    <Setter Property="TextOptions.TextRenderingMode"  Value="Auto"/>
  </Style>

  <!-- ============================================================
       6. BUTTONS
       ============================================================ -->

  <!-- Primary: filled accent. -->
  <Style x:Key="ZuneButtonPrimary" TargetType="Button">
    <Setter Property="Background"      Value="{StaticResource ZuneAccent}"/>
    <Setter Property="Foreground"      Value="{StaticResource ZuneForeground}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource ZuneAccent}"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="Padding"         Value="22,10"/>
    <Setter Property="FontFamily"      Value="Segoe UI"/>
    <Setter Property="FontSize"        Value="14"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment"   Value="Center"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background"  Value="{StaticResource ZuneAccentHot}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ZuneAccentHot}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background"  Value="{StaticResource ZuneAccentDeep}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ZuneAccentDeep}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Background"  Value="Transparent"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ZuneForeground5}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground4}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Secondary: white outline, transparent fill. -->
  <Style x:Key="ZuneButton" TargetType="Button" BasedOn="{StaticResource ZuneButtonPrimary}">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background"  Value="{StaticResource ZuneSurface3}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background"  Value="{StaticResource ZuneAccent}"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ZuneAccent}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ZuneForeground5}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground4}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Ghost: text only. -->
  <Style x:Key="ZuneButtonGhost" TargetType="Button" BasedOn="{StaticResource ZuneButton}">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground"  Value="{StaticResource ZuneForeground2}"/>
  </Style>

  <!-- Chrome button: 46×48 with consistent MDL2 glyphs (min/max/close all same metric). -->
  <Style x:Key="ZuneChromeButton" TargetType="Button">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="{StaticResource ZuneForeground2}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width"           Value="46"/>
    <Setter Property="Height"          Value="48"/>
    <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
    <Setter Property="FontSize"        Value="10"/>
    <Setter Property="Cursor"          Value="Arrow"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource ZuneLine}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource ZuneLineStrong}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Close variant — red on hover. -->
  <Style x:Key="ZuneChromeCloseButton" TargetType="Button" BasedOn="{StaticResource ZuneChromeButton}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource ZuneDanger}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="#FFB30E00"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Danger: red fill — destructive primary only. -->
  <Style x:Key="ZuneButtonDanger" TargetType="Button" BasedOn="{StaticResource ZuneButtonPrimary}">
    <Setter Property="Background"  Value="{StaticResource ZuneDanger}"/>
    <Setter Property="BorderBrush" Value="{StaticResource ZuneDanger}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background"  Value="#FFFF2814"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="#FFFF2814"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background"  Value="#FFB30E00"/>
              <Setter TargetName="Root" Property="BorderBrush" Value="#FFB30E00"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       7. TEXT BOX
       ============================================================ -->
  <Style x:Key="ZuneTextBox" TargetType="TextBox">
    <Setter Property="Background"          Value="Transparent"/>
    <Setter Property="Foreground"          Value="{StaticResource ZuneForeground}"/>
    <Setter Property="CaretBrush"          Value="{StaticResource ZuneAccent}"/>
    <Setter Property="SelectionBrush"      Value="{StaticResource ZuneAccent}"/>
    <Setter Property="SelectionOpacity"    Value="0.5"/>
    <Setter Property="BorderBrush"         Value="{StaticResource ZuneForeground}"/>
    <Setter Property="BorderThickness"     Value="2"/>
    <Setter Property="Padding"             Value="16,12"/>
    <Setter Property="MinHeight"           Value="44"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="FontFamily"          Value="Segoe UI"/>
    <Setter Property="FontSize"            Value="16"/>
    <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="BorderElement"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  SnapsToDevicePixels="True">
            <ScrollViewer x:Name="PART_ContentHost"
                          Padding="{TemplateBinding Padding}"
                          Focusable="False"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="BorderElement" Property="BorderBrush" Value="{StaticResource ZuneAccent}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="BorderElement" Property="BorderBrush" Value="{StaticResource ZuneForeground5}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground4}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       8. CHECK BOX — square, accent fill when checked
       ============================================================ -->
  <Style x:Key="ZuneCheckBox" TargetType="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="Cursor"     Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal" Background="Transparent">
            <Border x:Name="Box" Width="18" Height="18"
                    BorderThickness="2"
                    BorderBrush="{StaticResource ZuneForeground3}"
                    Background="Transparent"
                    VerticalAlignment="Center"
                    SnapsToDevicePixels="True">
              <Path x:Name="Check"
                    Stroke="{StaticResource ZuneForeground}"
                    StrokeThickness="2"
                    Data="M 2,7 L 6,11 L 12,3"
                    Visibility="Collapsed"
                    SnapsToDevicePixels="True"/>
            </Border>
            <ContentPresenter Margin="10,0,0,0"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Box"   Property="Background"  Value="{StaticResource ZuneAccent}"/>
              <Setter TargetName="Box"   Property="BorderBrush" Value="{StaticResource ZuneAccent}"/>
              <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource ZuneForeground}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource ZuneForeground5}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground4}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       9. TOGGLE SWITCH — the iconic Zune slider as a styled ToggleButton
          90×28 track, 2px border, 14×28 thumb that slides on toggle.
       ============================================================ -->
  <Style x:Key="ZuneToggleSwitch" TargetType="ToggleButton">
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="Cursor"     Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{StaticResource ZuneForeground3}"/>
    <Setter Property="HorizontalAlignment" Value="Left"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ContentPresenter Grid.Column="0"
                              VerticalAlignment="Center"
                              TextElement.Foreground="{StaticResource ZuneForeground2}"
                              Margin="0,0,12,0"
                              RecognizesAccessKey="True"/>

            <Border x:Name="Track" Grid.Column="1"
                    Width="44" Height="22"
                    BorderBrush="{StaticResource ZuneForeground3}"
                    BorderThickness="2"
                    Background="Transparent"
                    VerticalAlignment="Center"
                    SnapsToDevicePixels="True">
              <Canvas ClipToBounds="True">
                <Border x:Name="Thumb"
                        Width="14" Height="22"
                        Canvas.Left="-2" Canvas.Top="-2"
                        Background="{StaticResource ZuneForeground}"
                        SnapsToDevicePixels="True">
                  <Border.RenderTransform>
                    <TranslateTransform x:Name="ThumbXform" X="0"/>
                  </Border.RenderTransform>
                </Border>
              </Canvas>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Track" Property="Background"  Value="{StaticResource ZuneAccent}"/>
              <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource ZuneAccent}"/>
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ThumbXform"
                                     Storyboard.TargetProperty="X"
                                     To="30" Duration="0:0:0.22">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ThumbXform"
                                     Storyboard.TargetProperty="X"
                                     To="0" Duration="0:0:0.22">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource ZuneForeground}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource ZuneForeground5}"/>
              <Setter TargetName="Thumb" Property="Background"  Value="{StaticResource ZuneForeground5}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground4}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       10. LIST VIEW — chromeless, settings-style rows
       ============================================================ -->
  <Style x:Key="ZuneListViewItem" TargetType="ListViewItem">
    <Setter Property="Padding"     Value="12,10"/>
    <Setter Property="Margin"      Value="0"/>
    <Setter Property="MinHeight"   Value="0"/>
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground"  Value="{StaticResource ZuneForeground}"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListViewItem">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource ZuneSurface1}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource ZuneSurface3}"/>
              <Setter Property="Foreground" Value="{StaticResource ZuneAccent}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ZuneListView" TargetType="ListView">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground"      Value="{StaticResource ZuneForeground}"/>
    <Setter Property="ItemContainerStyle" Value="{StaticResource ZuneListViewItem}"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
  </Style>

  <!-- ============================================================
       11. TAB CONTROL — Pivot replacement
       ============================================================ -->
  <Style x:Key="ZuneTabItem" TargetType="TabItem">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground"  Value="{StaticResource ZuneForeground4}"/>
    <Setter Property="FontFamily"  Value="Segoe UI Light"/>
    <Setter Property="FontWeight"  Value="Light"/>
    <Setter Property="FontSize"    Value="44"/>
    <Setter Property="Padding"     Value="0,0,28,8"/>
    <Setter Property="Margin"      Value="0,0,28,0"/>
    <Setter Property="Cursor"      Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="Root" Background="Transparent" Padding="{TemplateBinding Padding}">
            <ContentPresenter ContentSource="Header"
                              TextElement.Foreground="{TemplateBinding Foreground}"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground2}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ZuneTabControl" TargetType="TabControl">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="0"/>
    <Setter Property="ItemContainerStyle" Value="{StaticResource ZuneTabItem}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabControl">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TabPanel Grid.Row="0"
                      IsItemsHost="True"
                      Background="Transparent"
                      Margin="0,0,0,16"/>
            <ContentPresenter Grid.Row="1"
                              ContentSource="SelectedContent"/>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       12. SLIDER — vertical-bar thumb on a 2px track
       ============================================================ -->
  <Style x:Key="ZuneSliderRepeatButton" TargetType="RepeatButton">
    <Setter Property="OverridesDefaultStyle" Value="True"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="IsTabStop" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border Background="Transparent"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ZuneSliderThumb" TargetType="Thumb">
    <Setter Property="OverridesDefaultStyle" Value="True"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Rectangle Fill="{StaticResource ZuneForeground}" Width="8" Height="24"
                     SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ZuneSlider" TargetType="Slider">
    <Setter Property="Foreground" Value="{StaticResource ZuneAccent}"/>
    <Setter Property="Background" Value="{StaticResource ZuneForeground5}"/>
    <Setter Property="MinHeight"  Value="24"/>
    <Setter Property="Focusable"  Value="False"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid Height="24">
            <Rectangle Height="2" Fill="{TemplateBinding Background}" VerticalAlignment="Center"/>
            <Track x:Name="PART_Track" Height="24">
              <Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource ZuneSliderRepeatButton}" Command="Slider.DecreaseLarge"/>
              </Track.DecreaseRepeatButton>
              <Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource ZuneSliderRepeatButton}" Command="Slider.IncreaseLarge"/>
              </Track.IncreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource ZuneSliderThumb}"/>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       13. PROGRESS BAR — flat, accent fill
       ============================================================ -->
  <Style x:Key="ZuneProgressBar" TargetType="ProgressBar">
    <Setter Property="Background"      Value="{StaticResource ZuneSurface3}"/>
    <Setter Property="Foreground"      Value="{StaticResource ZuneAccent}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource ZuneLineStrong}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Height"          Value="4"/>
    <Setter Property="MinHeight"       Value="4"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
            <Rectangle x:Name="PART_Track"/>
            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
              <Rectangle Fill="{TemplateBinding Foreground}"/>
            </Decorator>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================================================
       14. MENU / CONTEXT MENU
       ============================================================ -->
  <Style x:Key="ZuneMenu" TargetType="Menu">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground2}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="13"/>
  </Style>

  <Style x:Key="ZuneMenuItem" TargetType="MenuItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="14,8"/>
  </Style>

  <Style x:Key="ZuneContextMenu" TargetType="ContextMenu">
    <Setter Property="Background"      Value="{StaticResource ZuneBackground}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource ZuneLine}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground"      Value="{StaticResource ZuneForeground}"/>
    <Setter Property="Padding"         Value="0,6,0,6"/>
  </Style>

  <!-- ============================================================
       15. SCROLL BAR — minimal sliver
       ============================================================ -->
  <Style x:Key="ZuneScrollBarThumb" TargetType="Thumb">
    <Setter Property="OverridesDefaultStyle" Value="True"/>
    <Setter Property="IsTabStop" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border Background="{StaticResource ZuneForeground5}" SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Thumb">
              <Border Background="{StaticResource ZuneForeground4}" SnapsToDevicePixels="True"/>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width" Value="6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="Transparent">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
              <Track.Thumb>
                <Thumb Style="{StaticResource ZuneScrollBarThumb}"/>
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
              </Track.IncreaseRepeatButton>
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
              </Track.DecreaseRepeatButton>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="Transparent">
                <Track x:Name="PART_Track" IsDirectionReversed="False">
                  <Track.Thumb>
                    <Thumb Style="{StaticResource ZuneScrollBarThumb}"/>
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                  </Track.IncreaseRepeatButton>
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                  </Track.DecreaseRepeatButton>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ============================================================
       16. STATUS BAR
       ============================================================ -->
  <Style x:Key="ZuneStatusBar" TargetType="StatusBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource ZuneForeground3}"/>
    <Setter Property="BorderBrush" Value="{StaticResource ZuneLine}"/>
    <Setter Property="BorderThickness" Value="0,1,0,0"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
    <Setter Property="FontSize"   Value="12"/>
  </Style>

  <!-- ============================================================
       17. PAGE-ENTER STORYBOARD
       Apply on a Page or Window root's Loaded event for the parallax twist feel.
       Caller must set RenderTransform="<TranslateTransform/>" on the target.
       ============================================================ -->
  <Storyboard x:Key="ZunePageEnter">
    <DoubleAnimation
        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
        From="80" To="0" Duration="0:0:0.65">
      <DoubleAnimation.EasingFunction>
        <CubicEase EasingMode="EaseOut"/>
      </DoubleAnimation.EasingFunction>
    </DoubleAnimation>
    <DoubleAnimation
        Storyboard.TargetProperty="Opacity"
        From="0" To="1" Duration="0:0:0.4"/>
  </Storyboard>

</ResourceDictionary>
