<Window x:Class="ClipSage.App.CachingFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipSage.App"
        mc:Ignorable="d"
        Title="clipsage / caching folder setup"
        MinHeight="500" MinWidth="600"
        SizeToContent="Height" Width="640"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ZuneWindow}">

    <Grid Margin="48,32,48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title — bleed off right edge. -->
        <TextBlock Grid.Row="0"
                   FontFamily="Segoe UI Light" FontWeight="Light"
                   FontSize="64"
                   Foreground="{StaticResource ZuneForeground}"
                   Text="caching folder"
                   Margin="0,0,-200,24"/>

        <!-- Welcome text. -->
        <StackPanel Grid.Row="1" Margin="0,0,0,24">
            <TextBlock Style="{StaticResource ZuneEyebrow}"
                       Text="WELCOME TO CLIPSAGE"
                       Foreground="{StaticResource ZuneAccent}"
                       Margin="0,0,0,12"/>
            <TextBlock Style="{StaticResource ZuneBody}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12">
                to enable clipboard data syncing between your devices, select a folder where clipsage will store its cache files.
            </TextBlock>
            <TextBlock Style="{StaticResource ZuneBody}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12">
                <Run Foreground="{StaticResource ZuneAccent}" FontWeight="SemiBold">recommendation —</Run>
                <Run>choose a folder in onedrive, google drive, dropbox, or another cloud storage service to sync clipboard data across multiple computers.</Run>
            </TextBlock>
            <TextBlock Style="{StaticResource ZuneBody}"
                       FontSize="14"
                       TextWrapping="Wrap">
                if you've used clipsage before, select your existing cache folder and your clipboard history will be preserved.
            </TextBlock>
        </StackPanel>

        <!-- Folder label. -->
        <TextBlock Grid.Row="2"
                   Style="{StaticResource ZuneEyebrow}"
                   Text="CACHING FOLDER"
                   Margin="0,0,0,8"/>

        <!-- Folder selection. -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="CachingFolderTextBox" Grid.Column="0"
                     Style="{StaticResource ZuneTextBox}"
                     FontSize="14" Padding="14,8"
                     Margin="0,0,12,0"
                     TextChanged="CachingFolderTextBox_TextChanged"/>

            <Button Grid.Column="1"
                    Style="{StaticResource ZuneButton}"
                    Content="browse"
                    Padding="22,10"
                    Click="BrowseButton_Click"/>
        </Grid>

        <!-- Warning. -->
        <Border Grid.Row="4"
                Background="{StaticResource ZuneSurface2}"
                BorderBrush="{StaticResource ZuneAccent}"
                BorderThickness="2,0,0,0"
                Padding="20,16"
                Margin="0,0,0,24">
            <TextBlock Style="{StaticResource ZuneBody}"
                       FontSize="13"
                       TextWrapping="Wrap">
                <Run Foreground="{StaticResource ZuneAccent}" FontWeight="SemiBold">note —</Run>
                <Run>a caching folder is required to use clipsage. if you select a folder with existing cache data, it will be reused. the application can't start without one.</Run>
            </TextBlock>
        </Border>

        <!-- Buttons. -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Style="{StaticResource ZuneButton}"
                    Content="help"
                    Padding="22,10"
                    Margin="0,0,12,0"
                    Click="SkipButton_Click"/>
            <Button Grid.Column="2"
                    Style="{StaticResource ZuneButtonPrimary}"
                    Content="continue"
                    Padding="22,10"
                    Click="SaveButton_Click"/>
        </Grid>
    </Grid>
</Window>
