<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ClipSage.App.PortableSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipSage.App"
        mc:Ignorable="d"
        Title="clipsage / portable setup"
        Height="540" Width="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource ZuneWindow}">

    <Grid Margin="48,32,48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title. -->
        <TextBlock Grid.Row="0"
                   FontFamily="Segoe UI Light" FontWeight="Light"
                   FontSize="64"
                   Foreground="{StaticResource ZuneForeground}"
                   Text="portable setup"
                   Margin="0,0,-200,24"/>

        <!-- Current location. -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource ZuneEyebrow}" Text="CURRENT LOCATION" Margin="0,0,0,6"/>
            <TextBlock x:Name="CurrentLocationTextBlock"
                       Text="C:\Path\To\Current\Location"
                       Foreground="{StaticResource ZuneForeground2}"
                       TextWrapping="Wrap"
                       FontFamily="Consolas"
                       FontSize="13"/>
        </StackPanel>

        <!-- Destination. -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource ZuneEyebrow}" Text="DESTINATION" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DestinationFolderTextBox" Grid.Column="0"
                         Style="{StaticResource ZuneTextBox}"
                         FontSize="14" Padding="14,8"
                         Margin="0,0,12,0"
                         TextChanged="DestinationFolderTextBox_TextChanged"/>
                <Button Grid.Column="1"
                        Style="{StaticResource ZuneButton}"
                        Content="browse"
                        Padding="22,10"
                        Click="BrowseButton_Click"/>
            </Grid>
        </StackPanel>

        <!-- Shortcut options. -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource ZuneEyebrow}" Text="SHORTCUTS" Margin="0,0,0,12"/>
            <CheckBox x:Name="CreateDesktopShortcutCheckBox"
                      Style="{StaticResource ZuneCheckBox}"
                      Content="create desktop shortcut"
                      IsChecked="True"
                      Margin="0,0,0,10"/>
            <CheckBox x:Name="CreateStartMenuShortcutCheckBox"
                      Style="{StaticResource ZuneCheckBox}"
                      Content="create start menu shortcut"
                      IsChecked="True"/>
        </StackPanel>

        <!-- OneDrive warning. -->
        <Border x:Name="OneDriveWarningPanel" Grid.Row="4"
                Background="{StaticResource ZuneSurface2}"
                BorderBrush="{StaticResource ZuneAccent}"
                BorderThickness="2,0,0,0"
                Padding="20,16"
                Margin="0,0,0,20"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Style="{StaticResource ZuneEyebrow}"
                           Text="ONEDRIVE LOCATION DETECTED"
                           Foreground="{StaticResource ZuneAccent}"
                           Margin="0,0,0,6"/>
                <TextBlock Style="{StaticResource ZuneBody}"
                           FontSize="13"
                           TextWrapping="Wrap">
                    using onedrive for your cache location is a good choice for syncing clipboard history between devices, but the cache file may occasionally be locked during sync operations.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Status message. -->
        <TextBlock Grid.Row="5"
                   x:Name="StatusMessageTextBlock"
                   Foreground="{StaticResource ZuneDanger}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,0,0,16"/>

        <!-- Buttons. -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Style="{StaticResource ZuneButton}"
                    Content="cancel"
                    Padding="22,10"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="SetupButton"
                    Style="{StaticResource ZuneButtonPrimary}"
                    Content="setup"
                    Padding="22,10"
                    Click="SetupButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
